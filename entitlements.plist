<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for WKWebView JavaScript JIT under hardened runtime -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Microphone access for speech-to-text recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- AppleScript access for browser URL detection (context_detect.rs) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Data Protection Keychain for API key storage (credentials.rs) -->
    <key>keychain-access-groups</key>
    <array>
        <string>HZ3F4JWGL9.com.sumivoice.app</string>
        <string>HZ3F4JWGL9.com.sumivoice.app.dev</string>
    </array>
</dict>
</plist>
